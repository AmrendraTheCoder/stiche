{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/dashboard",   "destination": "/dashboard.html" },
    { "source": "/onboarding",  "destination": "/onboarding.html" },
    { "source": "/api/(.*)",    "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  }
}
